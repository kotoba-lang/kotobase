{:kotobase.coverage/version 1
 :maturity :m4
 ;; M0-M6 template borrowed from kotoba-lang/kotoba-lang's docs/lang/coverage.edn,
 ;; adapted for this repo's shape: a single Clojure protocol (IStore) verified
 ;; by one shared contract test run against two backends, not a capability/
 ;; policy language with a deny-by-default gate. Where that adaptation changes
 ;; what a stage means (M3 in particular), the stage says so explicitly.
 :stages
 [{:stage :m0
   :name "constants-and-docs"
   :evidence ["README.md"]}
  {:stage :m1
   :name "machine-checkable-contract"
   :note "No separate EDN schema exists (or is needed) for a 5-method
          protocol; the protocol definition IS the machine-checkable
          contract, and test/kotobase/contract.cljc is the executable
          spec every backend must satisfy."
   :evidence ["src/kotobase/store.cljc"
              "test/kotobase/contract.cljc"]}
  {:stage :m2
   :name "positive-fixtures"
   :evidence ["test/kotobase/store_test.cljc:local-store-satisfies-contract"
              "test/kotobase/store_test.cljc:kotobase-store-equals-local"]}
  {:stage :m3
   :name "boundary-fixtures"
   :note "IStore is a total data-store contract with no capability/policy
          denial surface, unlike kotoba-lang's checkers -- there is nothing
          to reject. M3 here means the boundary cases actually baked into
          the shared contract test, not deny/error fixtures."
   :evidence ["test/kotobase/contract.cljc: get of a missing key is nil"
              "test/kotobase/contract.cljc: read past the tip is empty"]}
  {:stage :m4
   :name "ci-gated-runner"
   :evidence [".github/workflows/ci.yml (clojure -M:test on JDK 17 + 21)"]}
  {:stage :m5
   :name "external-implementation-suite"
   :status :unconfirmed
   :note "README's Consumers section names cloud-murakumo and
          cloud-manimani, but both actually depend on
          io.github.com-junkawasaki/kotobase-clj
          (orgs/com-junkawasaki/kotobase-clj) -- a DIFFERENT repo with an
          identical file/namespace layout (kotobase.store/local/kotobase,
          the same contract test), not this repo. kotobase-clj's own
          deps.edn comment says it has since been transferred to a
          gftdcojp/ org. Whether that repo is a stale fork, a pre-rename
          copy, or the actual currently-consumed artifact is unresolved.
          Do not claim M5 for kotoba-lang/kotobase until a real dependent
          names THIS repo -- flagged as a follow-up, not fixed here."
   :evidence []}
  {:stage :m6
   :name "compatibility-policy"
   :evidence ["docs/versioning.md"]}]}
