{:paths ["src"]
 ;; Zero-third-party-dep, all-`.cljc`: the IStore port + the pure LocalStore +
 ;; the KotobaseStore (which talks to kotobase.net through a HOST-INJECTED `xrpc`
 ;; fn — no HTTP client baked in, so it runs unchanged on JVM / cljs / a Cloudflare
 ;; Worker / kotoba-WASM). The injecting host supplies the transport (`fetch`).
 :deps {io.github.kotoba-lang/security {:git/url "https://github.com/kotoba-lang/security.git"
                                        :git/sha "49fc4ce359752e9fe6e547e9071b5b9b40da937a"}}
 :aliases
 {:cljs-test {:extra-paths ["test"]
              :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :integration {:extra-paths ["test-integration"]
                :extra-deps {io.github.kotoba-lang/kotoba
                             {:local/root "../kotoba"}
                             io.github.cognitect-labs/test-runner
                             {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                :main-opts ["-m" "cognitect.test-runner" "-d" "test-integration"]}
       ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
       :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
